# Facebook API konfigurace
# Pro získání těchto hodnot:
# 1. Jděte na https://developers.facebook.com/
# 2. Vytvořte novou aplikaci
# 3. Přidejte "Facebook Login" a "Graph API"
# 4. Získejte Page Access Token pro svou stránku

# ID vaší Facebook stránky (již máte: 61574874071299)
NEXT_PUBLIC_FACEBOOK_PAGE_ID=61574874071299

# Access Token pro vaši Facebook stránku
# POZOR: Tento token by měl být PRIVÁTNÍ (bez NEXT_PUBLIC_ prefixu)
# Získejte váš token na https://developers.facebook.com/tools/explorer/
FACEBOOK_ACCESS_TOKEN=EAAWPfMaYnp4BO2cCewcjc6CcB8FtlwqVI7yFR8c28YZAZB8MPeK3rPB2cbSfke0RavmrVLw5RE8LbRZBGHQO4w3YbXlysf0l6a31j1jbPBNTmAgYOtTAQ5pvHtCdXKziZAM5vr24ZCHIfkmampDFLjo5ZAavVJipUGtc1WzH5ARyEgETCFCZAuLXFw9b4SNpQRXEcdHrqKDtvKD9U3pZATE2eAM2nAGZCP87y

# App Secret z Facebook Developer Console
# POZOR: Tento secret by měl být PRIVÁTNÍ (bez NEXT_PUBLIC_ prefixu)
FACEBOOK_APP_SECRET=a8732acf3c1b1f3f348093b67c38086a

# Pro development můžete použít mock data (nastavte na "true")
NEXT_PUBLIC_USE_MOCK_DATA=true

# Maximální počet příspěvků k zobrazení
NEXT_PUBLIC_MAX_POSTS=6

# Resend API konfigurace pro odesílání e-mailů
# Pro získání API klíče:
# 1. Jděte na https://resend.com/
# 2. Zaregistrujte se a přihlaste se
# 3. V dashboard klikněte na "API Keys"
# 4. Vytvořte nový API klíč s názvem "Pavel Fišer Web"
# 5. Zkopírujte API klíč a vložte ho níže
# POZOR: Tento klíč by měl být PRIVÁTNÍ (bez NEXT_PUBLIC_ prefixu)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# E-mailová adresa pro odesílání (musí být ověřená doména v Resend)
# Pro testování můžete použít: onboarding@resend.dev
# Pro produkci: noreply@pavelfiser.cz (po ověření domény)
RESEND_FROM_EMAIL=onboarding@resend.dev

# E-mailová adresa pro přijímání zpráv z kontaktního formuláře
RESEND_TO_EMAIL=pavel.fiser@praha4.cz
