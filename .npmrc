# .npmrc
# This file can be used to configure npm behavior.

# Example: Set a default registry
# registry=https://registry.npmjs.org/

# Example: Set a default authentication token (for private registries)
# //registry.npmjs.org/:_authToken=YOUR_AUTH_TOKEN

# Example: Disable package-lock.json generation (not recommended for most projects)
# package-lock=false

# Example: Set a default save-exact behavior
# save-exact=true

# Example: Configure a proxy
# proxy=http://proxy.example.com:8080/
# https-proxy=http://proxy.example.com:8080/

# Example: Ignore scripts (for security reasons)
# ignore-scripts=true

# Example: Set a cache directory
# cache=/tmp/npm-cache

# Enable pnpm for faster and more efficient package management
# This file tells npm to use pnpm for package installation.
# If you prefer npm, you can remove or comment out this line.
# For more info: https://pnpm.io/npmrc
shrinkwrap=true
